    "plugin/build",
    "app.plugin.js",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "app.plugin.js": "./app.plugin.js",
  "peerDependencies": {
    "expo": "^54.0.33",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
